# Build artifacts
/dist/
/Userskhangbinsqlitedeploy.exe

# Runtime data
/data/

# Local credentials and runtime config
/.sqlitedeploy/

# Local Claude Code settings
/.claude/settings.local.json

# Test scratch space and tooling venvs (recreated by test/run-all.sh)
/.venv-tools/
/test/.scratch/

# Python bytecode caches (hatch_build.py picks one up during wheel build)
__pycache__/
*.pyc

# Maven build outputs (target/) and per-platform binaries copied in by
# `make package-maven` before `mvn package` runs.
/packaging/maven/**/target/
/packaging/maven/platforms/*/src/main/resources/META-INF/native/
